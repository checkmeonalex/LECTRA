{
  "expo": {
    "name": "LECTRA",
    "slug": "LECTRA",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app_icon-trans.png",
    "scheme": "lectra",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/app_icon-trans.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app_icon-trans.png",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.alxdev.LECTRA"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/app_icon-trans.png",
          "imageWidth": 200,
          "android": {
            "image": "./assets/images/app_icon-trans.png",
            "imageWidth": 200,
            "backgroundColor": "#FFFFFF"
          }
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "29cd33b1-48f9-4e37-acc3-2bdc570d02e8"
      }
    },
    "owner": "alx-dev",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/29cd33b1-48f9-4e37-acc3-2bdc570d02e8"
    }
  }
}
